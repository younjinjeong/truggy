<?xml version="1.0" ?>
<!-- TruggyAD 1/8 Scale RC Truggy Model for Gazebo Harmonic -->
<sdf version="1.9">
  <model name="truggy">
    <static>false</static>

    <!-- Chassis -->
    <link name="chassis">
      <pose>0 0 0.08 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.05</ixx><iyy>0.08</iyy><izz>0.04</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <geometry>
          <box><size>0.45 0.25 0.12</size></box>
        </geometry>
      </collision>
      <visual name="chassis_visual">
        <geometry>
          <box><size>0.45 0.25 0.12</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.8 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
        </material>
      </visual>

      <!-- Stereo camera (ZED) -->
      <sensor name="stereo_camera" type="camera">
        <pose>0.15 0 0.15 0 0.21 0</pose>  <!-- 12° downward -->
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.74</horizontal_fov>  <!-- ~100° -->
          <image>
            <width>1280</width>
            <height>720</height>
          </image>
          <clip><near>0.3</near><far>20</far></clip>
        </camera>
        <always_on>true</always_on>
      </sensor>

      <!-- Depth camera (simulates ZED depth) -->
      <sensor name="depth_camera" type="depth_camera">
        <pose>0.15 0 0.15 0 0.21 0</pose>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.74</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
          </image>
          <clip><near>0.3</near><far>20</far></clip>
        </camera>
        <always_on>true</always_on>
      </sensor>

      <!-- IMU -->
      <sensor name="imu" type="imu">
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <always_on>true</always_on>
      </sensor>
    </link>

    <!-- Front Left Wheel -->
    <link name="front_left_wheel">
      <pose>0.175 0.15 0.06 -1.5708 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>

    <!-- Front Right Wheel -->
    <link name="front_right_wheel">
      <pose>0.175 -0.15 0.06 -1.5708 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>

    <!-- Rear Left Wheel -->
    <link name="rear_left_wheel">
      <pose>-0.175 0.15 0.06 -1.5708 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>

    <!-- Rear Right Wheel -->
    <link name="rear_right_wheel">
      <pose>-0.175 -0.15 0.06 -1.5708 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.2</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>

    <!-- Joints -->
    <joint name="front_left_steering" type="revolute">
      <parent>chassis</parent><child>front_left_wheel</child>
      <axis><xyz>0 0 1</xyz>
        <limit><lower>-0.5</lower><upper>0.5</upper></limit>
      </axis>
    </joint>

    <joint name="front_right_steering" type="revolute">
      <parent>chassis</parent><child>front_right_wheel</child>
      <axis><xyz>0 0 1</xyz>
        <limit><lower>-0.5</lower><upper>0.5</upper></limit>
      </axis>
    </joint>

    <joint name="rear_left_drive" type="revolute">
      <parent>chassis</parent><child>rear_left_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <joint name="rear_right_drive" type="revolute">
      <parent>chassis</parent><child>rear_right_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Ackermann steering plugin -->
    <plugin filename="gz-sim-ackermann-steering-system"
            name="gz::sim::systems::AckermannSteering">
      <left_joint>front_left_steering</left_joint>
      <right_joint>front_right_steering</right_joint>
      <left_joint>rear_left_drive</left_joint>
      <right_joint>rear_right_drive</right_joint>
      <wheel_separation>0.30</wheel_separation>
      <kingpin_width>0.30</kingpin_width>
      <wheel_base>0.35</wheel_base>
      <wheel_radius>0.06</wheel_radius>
      <steering_limit>0.5</steering_limit>
      <topic>cmd_vel</topic>
    </plugin>
  </model>
</sdf>
